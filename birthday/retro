<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>You have a birthday surprise! 🎊</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎊</text></svg>">
<meta property="og:title" content="You have a birthday surprise! 🎊">
<meta property="og:description" content="Someone made you a Retro Party birthday card!">
<meta property="og:image" content="https://wishyou.ai/og-image.png">
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Patrick+Hand&family=DM+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
body{font-family:'DM Sans',sans-serif;background:#111;display:flex;align-items:center;justify-content:center;}

.app{position:relative;width:100%;max-width:430px;height:100vh;overflow:hidden;margin:0 auto;}
@media(min-width:500px){
  .app{height:90vh;max-height:900px;border-radius:40px;overflow:hidden;box-shadow:0 40px 120px rgba(0,0,0,0.8);}
}

.screen{
  position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;
  transition:opacity 0.5s ease,transform 0.5s cubic-bezier(.4,0,.2,1);
  transform:translateY(30px);overflow-y:auto;-webkit-overflow-scrolling:touch;
}
.screen.active{opacity:1;pointer-events:all;transform:translateY(0);}
.screen.out{opacity:0;transform:translateY(-30px);}

/* LOADING */
#s-loading{background:#FFE135;}
.loading-cake{font-size:3rem;animation:bounce 0.8s ease-in-out infinite alternate;}
@keyframes bounce{from{transform:translateY(0);}to{transform:translateY(-12px);}}
.loading-text{font-family:'Fredoka One',cursive;font-size:1.1rem;color:#d90429;margin-top:14px;}

/* ERROR */
#s-error{background:#FFE135;text-align:center;padding:40px;}
.error-emoji{font-size:3rem;margin-bottom:16px;display:block;}
.error-text{font-family:'Fredoka One',cursive;font-size:1.1rem;color:#111;line-height:1.7;}

/* WELCOME */
#s-welcome{background:#FFE135;}
.confetti-bg{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.conf{position:absolute;animation:cf linear infinite;font-size:1.2rem;}
@keyframes cf{0%{transform:translateY(-20px) rotate(0deg);opacity:0;}10%{opacity:1;}90%{opacity:0.5;}100%{transform:translateY(100vh) rotate(540deg);opacity:0;}}
.w-inner{position:relative;z-index:2;text-align:center;padding:32px 28px;width:100%;}
.retro-tag{font-family:'Fredoka One',cursive;font-size:0.75rem;letter-spacing:0.15em;color:rgba(0,0,0,0.3);margin-bottom:16px;display:block;text-transform:uppercase;}
.w-cake{font-size:4rem;display:block;margin-bottom:16px;animation:bounce 1s ease-in-out infinite alternate;}
.retro-headline{font-family:'Fredoka One',cursive;font-size:clamp(1.8rem,7vw,2.6rem);color:#d90429;line-height:1.1;margin-bottom:6px;text-shadow:3px 3px 0 rgba(0,0,0,0.1);}
.retro-sub{font-family:'Patrick Hand',cursive;font-size:0.9rem;color:#333;margin-bottom:6px;line-height:1.5;}
.retro-from{font-family:'Patrick Hand',cursive;font-size:0.85rem;color:rgba(0,0,0,0.4);margin-bottom:32px;}
.retro-open-btn{
  background:#d90429;color:white;border:3px solid #111;border-radius:8px;
  padding:14px 40px;font-family:'Fredoka One',cursive;font-size:1.1rem;
  cursor:pointer;box-shadow:4px 4px 0 #111;
  transition:transform 0.1s,box-shadow 0.1s;touch-action:manipulation;
}
.retro-open-btn:active{transform:translate(2px,2px);box-shadow:2px 2px 0 #111;}

/* COMIC PHOTOS */
#s-photos{background:#FFE135;padding:0;align-items:stretch;justify-content:flex-start;}
.comic-header{padding:44px 24px 16px;display:flex;align-items:center;gap:10px;}
.comic-title-wrap{flex:1;}
.comic-label{font-family:'Fredoka One',cursive;font-size:0.65rem;letter-spacing:0.12em;color:#d90429;text-transform:uppercase;margin-bottom:3px;display:block;}
.comic-title{font-family:'Fredoka One',cursive;font-size:1.3rem;color:#111;}

.comic-strip{flex:1;padding:4px 16px 12px;display:flex;gap:10px;overflow-x:auto;align-items:center;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;}
.comic-strip::-webkit-scrollbar{display:none;}
.comic-panel{
  flex-shrink:0;scroll-snap-align:center;
  border:3px solid #111;border-radius:4px;
  box-shadow:4px 4px 0 #111;overflow:hidden;
  background:white;
  transition:transform 0.2s;
}
.comic-panel:active{transform:scale(0.97);}
.comic-panel img{width:200px;height:220px;object-fit:cover;display:block;}
.comic-caption{font-family:'Fredoka One',cursive;font-size:0.7rem;color:#111;text-align:center;padding:6px 4px;border-top:2px solid #111;background:#fff9c4;}
.no-comic{text-align:center;padding:40px 20px;flex:1;display:flex;align-items:center;justify-content:center;}
.no-comic-text{font-family:'Fredoka One',cursive;font-size:1rem;color:#111;opacity:0.4;}

.retro-btn{margin:0 20px 20px;background:#d90429;color:white;border:3px solid #111;border-radius:8px;padding:13px;font-family:'Fredoka One',cursive;font-size:1rem;cursor:pointer;touch-action:manipulation;width:calc(100% - 40px);box-shadow:4px 4px 0 #111;transition:transform 0.1s,box-shadow 0.1s;}
.retro-btn:active{transform:translate(2px,2px);box-shadow:2px 2px 0 #111;}

/* SONG */
#s-song{background:#FFE135;padding:32px 28px;}
.vinyl-outer{width:140px;height:140px;margin:0 auto 22px;position:relative;}
.vinyl-r{width:100%;height:100%;border-radius:50%;background:conic-gradient(#111 0deg,#222 18deg,#111 36deg,#222 54deg,#111 72deg,#222 90deg,#111 108deg,#222 126deg,#111 144deg,#222 162deg,#111 180deg,#222 198deg,#111 216deg,#222 234deg,#111 252deg,#222 270deg,#111 288deg,#222 306deg,#111 324deg,#222 342deg,#111 360deg);box-shadow:0 6px 20px rgba(0,0,0,0.3),0 0 0 5px #333,0 0 0 7px #444;display:flex;align-items:center;justify-content:center;}
.vinyl-center-r{width:38px;height:38px;border-radius:50%;background:#FFE135;border:3px solid #111;display:flex;align-items:center;justify-content:center;font-size:1rem;font-family:'Fredoka One',cursive;color:#d90429;}
.vs{animation:vsr 3s linear infinite;}
@keyframes vsr{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
.vp{animation-play-state:paused;}
.song-headline{font-family:'Fredoka One',cursive;font-size:1.2rem;color:#111;text-align:center;margin-bottom:4px;}
.song-sub-r{font-family:'Patrick Hand',cursive;font-size:0.85rem;color:#333;opacity:0.6;text-align:center;margin-bottom:22px;}
.yt-wrap-r{width:100%;border-radius:6px;overflow:hidden;border:3px solid #111;box-shadow:4px 4px 0 #111;margin-bottom:20px;display:none;}
.yt-wrap-r iframe{width:100%;height:185px;border:none;display:block;}
.yt-wrap-r.show{display:block;}

/* BALLOON */
#s-balloon{background:#FFE135;}
.balloon-inner{text-align:center;padding:24px;}
.balloon-title{font-family:'Fredoka One',cursive;font-size:1.6rem;color:#111;margin-bottom:6px;}
.balloon-hint{font-family:'Patrick Hand',cursive;font-size:0.9rem;color:#333;opacity:0.55;margin-bottom:24px;}
.balloon-icon{font-size:5rem;display:block;cursor:pointer;animation:bf 1.5s ease-in-out infinite;transition:transform 0.15s;}
@keyframes bf{0%,100%{transform:translateY(0) rotate(-3deg);}50%{transform:translateY(-14px) rotate(3deg);}}
.balloon-icon:active{transform:scale(0.85) rotate(15deg)!important;}

/* NEWSPAPER LETTER */
#s-letter{background:#FFE135;padding:0;align-items:stretch;justify-content:flex-start;}
.newspaper-scroll{flex:1;padding:20px 20px 110px;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.newspaper-wrap{background:#fdf8e7;border:3px solid #111;border-radius:6px;box-shadow:5px 5px 0 #111;overflow:hidden;}
.news-masthead{background:#111;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;}
.news-name{font-family:'Fredoka One',cursive;font-size:0.85rem;color:#FFE135;letter-spacing:0.1em;}
.news-date{font-family:'Patrick Hand',cursive;font-size:0.65rem;color:rgba(255,225,53,0.5);}
.news-headline-bar{background:#d90429;padding:8px 16px;}
.news-headline{font-family:'Fredoka One',cursive;font-size:1rem;color:white;line-height:1.2;}
.news-body{padding:16px;}
.news-to{font-family:'Fredoka One',cursive;font-size:0.75rem;color:#d90429;margin-bottom:10px;display:block;}
.news-text{font-family:'Patrick Hand',cursive;font-size:0.95rem;color:#111;line-height:1.8;white-space:pre-wrap;}
.news-sign{font-family:'Fredoka One',cursive;font-size:0.9rem;color:#d90429;margin-top:14px;border-top:2px dashed rgba(0,0,0,0.1);padding-top:12px;}
.retro-foot{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;padding:14px 20px;background:linear-gradient(to top,#FFE135 55%,transparent);}

.wm{position:fixed;bottom:10px;right:14px;font-size:0.58rem;color:rgba(0,0,0,0.15);letter-spacing:0.08em;z-index:999;}
</style>
</head>
<body>
<div class="app">

  <div class="screen active" id="s-loading">
    <span class="loading-cake">🎂</span>
    <div class="loading-text">Loading your party card...</div>
  </div>

  <div class="screen" id="s-error">
    <span class="error-emoji">😢</span>
    <div class="error-text">This card has expired<br>or couldn't be found.</div>
  </div>

  <!-- WELCOME -->
  <div class="screen" id="s-welcome">
    <div class="confetti-bg" id="confetti"></div>
    <div class="w-inner">
      <span class="retro-tag">WishYou.ai</span>
      <span class="w-cake">🎂</span>
      <div class="retro-headline" id="wHeadline">Happy Birthday!</div>
      <div class="retro-sub" id="wSub">Someone special made this for you 🎊</div>
      <div class="retro-from" id="wFrom"></div>
      <button class="retro-open-btn" onclick="goTo('s-photos')">🎉 Open Your Card!</button>
    </div>
  </div>

  <!-- COMIC PHOTOS -->
  <div class="screen" id="s-photos">
    <div class="comic-header">
      <div class="comic-title-wrap">
        <span class="comic-label">Comic Strip 📸</span>
        <div class="comic-title">Your memories!</div>
      </div>
    </div>
    <div class="comic-strip" id="comicStrip"></div>
    <button class="retro-btn" onclick="goTo('s-song')">Next → Party Anthem 🎵</button>
  </div>

  <!-- SONG -->
  <div class="screen" id="s-song">
    <span class="comic-label" style="margin-bottom:16px;">Party Anthem 🎵</span>
    <div class="vinyl-outer">
      <div class="vinyl-r vs" id="vinyl">
        <div class="vinyl-center-r">🎵</div>
      </div>
    </div>
    <div class="song-headline" id="songT">Your Party Anthem</div>
    <div class="song-sub-r" id="songA">A song chosen just for you</div>
    <div class="yt-wrap-r" id="ytWrap"><div id="ytEmbed"></div></div>
    <button class="retro-btn" style="width:calc(100% - 40px);margin:0 20px;" onclick="goTo('s-balloon')">Next → Your Letter 🎈</button>
  </div>

  <!-- BALLOON -->
  <div class="screen" id="s-balloon">
    <div class="balloon-inner">
      <div class="balloon-title">A letter from them!</div>
      <div class="balloon-hint">Pop the balloon to reveal it 👆</div>
      <span class="balloon-icon" onclick="popBalloon()">🎈</span>
    </div>
  </div>

  <!-- NEWSPAPER LETTER -->
  <div class="screen" id="s-letter">
    <div class="newspaper-scroll">
      <div class="newspaper-wrap">
        <div class="news-masthead">
          <span class="news-name">🗞️ THE BIRTHDAY GAZETTE</span>
          <span class="news-date" id="newsDate"></span>
        </div>
        <div class="news-headline-bar">
          <div class="news-headline" id="newsHeadline">BREAKING: IT'S YOUR BIRTHDAY!</div>
        </div>
        <div class="news-body">
          <span class="news-to" id="newsTo">DEAR BIRTHDAY STAR,</span>
          <div class="news-text" id="newsText"></div>
          <div class="news-sign" id="newsSign"></div>
        </div>
      </div>
    </div>
    <div class="retro-foot">
      <button class="retro-btn" style="margin:0;" onclick="goTo('s-welcome')">🎊 Replay from start!</button>
    </div>
  </div>

</div>
<div class="wm">WishYou.ai</div>

<script>
const FIREBASE_URL = 'https://feeltwo-d28b0-default-rtdb.firebaseio.com/wishyou-cards';
let curScreen = 's-loading';

function goTo(id){
  const prev = document.getElementById(curScreen);
  const next = document.getElementById(id);
  if(!next || curScreen === id) return;
  if(prev){ prev.classList.remove('active'); prev.classList.add('out'); setTimeout(()=>prev.classList.remove('out'),500); }
  next.classList.add('active');
  curScreen = id;
  const v = document.getElementById('vinyl');
  if(id === 's-song') v.classList.remove('vp'); else v.classList.add('vp');
}

function initConfetti(){
  const wrap = document.getElementById('confetti');
  const emojis = ['🎉','🎊','⭐','🎈','✨','🎁','🎂','🥳'];
  for(let i=0;i<20;i++){
    const c = document.createElement('div');
    c.className = 'conf';
    c.textContent = emojis[Math.floor(Math.random()*emojis.length)];
    const s = 0.8+Math.random()*0.8;
    c.style.cssText=`font-size:${s}rem;left:${Math.random()*100}%;animation-duration:${6+Math.random()*8}s;animation-delay:${Math.random()*8}s;`;
    wrap.appendChild(c);
  }
}

async function loadCard(){
  const params = new URLSearchParams(window.location.search);
  const cardId = params.get('card');
  if(!cardId){ goTo('s-error'); return; }
  try{
    const res = await fetch(`${FIREBASE_URL}/${cardId}.json`);
    const d = await res.json();
    if(!d){ goTo('s-error'); return; }
    if(d.expiresAt && Date.now() > d.expiresAt){ goTo('s-error'); return; }
    fetch(`${FIREBASE_URL}/${cardId}/views.json`).then(r=>r.json()).then(v=>{
      fetch(`${FIREBASE_URL}/${cardId}/views.json`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify((v||0)+1)}).catch(()=>{});
    }).catch(()=>{});
    renderCard(d);
  } catch(e){ goTo('s-error'); }
}

function renderCard(d){
  const name = d.name||'';
  const age = d.age||'';
  const sender = d.sender||'';

  // Welcome
  let headline = 'Happy Birthday!';
  if(name && age) headline = `${name} turns ${age}! 🎂`;
  else if(name) headline = `Happy Birthday, ${name}!`;
  document.getElementById('wHeadline').textContent = headline;
  document.getElementById('wSub').textContent = sender ? `${sender} made this for you 🎊` : 'Someone made this for you 🎊';
  document.getElementById('wFrom').textContent = sender ? `From: ${sender} 🎉` : '';

  // News headline
  if(name && age) document.getElementById('newsHeadline').textContent = `BREAKING: ${name.toUpperCase()} TURNS ${age} TODAY!`;
  else if(name) document.getElementById('newsHeadline').textContent = `BREAKING: HAPPY BIRTHDAY ${name.toUpperCase()}!`;

  // Date
  const now = new Date();
  document.getElementById('newsDate').textContent = now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}).toUpperCase();

  // Comic photos
  const strip = document.getElementById('comicStrip');
  strip.innerHTML = '';
  const caps = ['POW! 💥','WOW! ⭐','YAY! 🎉','ZAP! ✨','BOOM! 🎊'];
  if(d.photos && d.photos.length > 0){
    d.photos.forEach((url,i)=>{
      const panel = document.createElement('div');
      panel.className = 'comic-panel';
      panel.innerHTML = `<img src="${url}" alt="photo" onerror="this.parentNode.style.display='none'"><div class="comic-caption">${caps[i]||'🎉'}</div>`;
      strip.appendChild(panel);
    });
  } else {
    strip.innerHTML = '<div class="no-comic"><div class="no-comic-text">🎊 A card made with love!</div></div>';
  }

  // Song
  const sn = d.songName||'';
  if(sn && sn !== '—'){
    document.getElementById('songT').textContent = sn;
    const sp = d.spotify||'';
    if(sp){
      const ytM = sp.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      if(ytM){
        const w = document.getElementById('ytWrap'); w.classList.add('show');
        document.getElementById('ytEmbed').innerHTML=`<iframe src="https://www.youtube.com/embed/${ytM[1]}" allow="autoplay" allowfullscreen></iframe>`;
      }
    }
  }

  // Letter
  document.getElementById('newsTo').textContent = name ? `DEAR ${name.toUpperCase()},` : 'DEAR BIRTHDAY STAR,';
  document.getElementById('newsText').textContent = d.msg||'';
  document.getElementById('newsSign').textContent = d.sign||(sender?`Reported with love, ${sender} 💛`:'Reported with love 💛');

  goTo('s-welcome');
}

function popBalloon(){
  const b = document.querySelector('.balloon-icon');
  b.style.transform = 'scale(1.4)';
  b.textContent = '💥';
  setTimeout(()=>{ b.style.transform=''; b.textContent='🎈'; goTo('s-letter'); }, 400);
}

initConfetti();
loadCard();
</script>
</body>
</html>
